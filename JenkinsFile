pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Nuth68/laravel-test-jenkins.git',
                    credentialsId: 'test'   // your git credential
            }
        }

        stage('Build Laravel') {
            steps {
                sh '''
                    echo "Installing dependencies..."
                    composer install

                    echo "Generating key..."
                    php artisan key:generate

                    echo "Installing npm..."
                    npm install

                    echo "Building assets..."
                    npm run build
                '''
            }
        }
    }

    post {

        success {
            echo "Build SUCCESS ✅"
            script {
                withCredentials([
                    string(credentialsId: '8623369528:AAEwgKFCr-Xxojkh8y4NDMMCpTfMoWIazVU', variable: 'TOKEN'),
                    string(credentialsId: '1653989745', variable: 'CHAT_ID')
                ]) {
                    sh """
                    curl -s -X POST https://api.telegram.org/bot${TOKEN}/sendMessage \
                    -d chat_id=${CHAT_ID} \
                    -d text="✅ SUCCESS: ${JOB_NAME} #${BUILD_NUMBER} \n${BUILD_URL}"
                    """
                }
            }
        }

        failure {
            echo "Build FAILED ❌"
            script {
                withCredentials([
                    string(credentialsId: '8623369528:AAEwgKFCr-Xxojkh8y4NDMMCpTfMoWIazVU', variable: 'TOKEN'),
                    string(credentialsId: '1653989745', variable: 'CHAT_ID')
                ]) {
                    sh """
                    curl -s -X POST https://api.telegram.org/bot${TOKEN}/sendMessage \
                    -d chat_id=${CHAT_ID} \
                    -d text="❌ FAILED: ${JOB_NAME} #${BUILD_NUMBER} \n${BUILD_URL}"
                    """
                }
            }
        }
    }
}