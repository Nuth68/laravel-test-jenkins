pipeline {
    agent any

    environment {
        TELEGRAM_TOKEN = credentials('8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo') // Jenkins credentials ID
        TELEGRAM_CHAT_ID = credentials('1653989745') // Jenkins credentials ID
    }

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/Nuth68/laravel-test-jenkins.git'
            }
        }

        stage('Build Laravel') {
            steps {
                sh '''
                composer install
                php artisan key:generate
                npm install
                npm run build
                '''
            }
        }
    }

    post {
        success {
            script {
                sh """
                curl -s -X POST https://api.telegram.org/bot${env.TELEGRAM_TOKEN}/sendMessage \
                -d chat_id=${env.TELEGRAM_CHAT_ID} \
                -d text='✅ SUCCESS: ${env.JOB_NAME}'
                """
            }
        }

        failure {
            script {
                sh """
                curl -s -X POST https://api.telegram.org/bot${env.TELEGRAM_TOKEN}/sendMessage \
                -d chat_id=${env.TELEGRAM_CHAT_ID} \
                -d text='❌ FAILED: ${env.JOB_NAME}'
                """
            }
        }
    }
}