pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/Nuth68/laravel-test-jenkins.git'
            }
        }

        stage('Build Laravel') {
            steps {
                sh '''
                    composer install
                    php artisan key:generate
                    npm install
                    npm run build
                '''
            }
        }
    }

    post {
        success {
            script {
                withCredentials([
                    string(credentialsId: '8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo', variable: 'TELEGRAM_TOKEN'),
                    string(credentialsId: '1653989745', variable: 'TELEGRAM_CHAT_ID')
                ]) {
                    node {
                        sh """
                            curl -s -X POST https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage \
                            -d chat_id=${TELEGRAM_CHAT_ID} \
                            -d text='✅ SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER} (${env.BUILD_URL})'
                        """
                    }
                }
            }
        }

        failure {
            script {
                withCredentials([
                    string(credentialsId: '8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo', variable: 'TELEGRAM_TOKEN'),
                    string(credentialsId: '1653989745', variable: 'TELEGRAM_CHAT_ID')
                ]) {
                    node {
                        sh """
                            curl -s -X POST https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage \
                            -d chat_id=${TELEGRAM_CHAT_ID} \
                            -d text='❌ FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER} (${env.BUILD_URL})'
                        """
                    }
                }
            }
        }
    }
}