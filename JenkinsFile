pipeline {
    agent { label 'docker-agent' }

    triggers {
        pollSCM('* * * * *')
    }

    environment {
        TELEGRAM_TOKEN = credentials('8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo')
        TELEGRAM_CHAT_ID = credentials('1653989745')

        TEXT_SUCCESS = "✅ Build SUCCESS: ${JOB_NAME}"
        TEXT_FAIL = "❌ Build FAILED: ${JOB_NAME}"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/Nuth68/laravel-test-jenkins.git'
            }
        }

        stage('Build Laravel') {
            steps {
                sh '''
                composer install
                php artisan key:generate
                npm install
                npm run build
                '''
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh '''
                ansible-playbook -i inventory.ini playbook.yml
                '''
            }
        }
    }

    post {

        success {
            sh '''
            curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
            -d chat_id="$TELEGRAM_CHAT_ID" \
            -d text="$TEXT_SUCCESS"
            '''
        }

        failure {
            sh '''
            curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
            -d chat_id="$TELEGRAM_CHAT_ID" \
            -d text="$TEXT_FAIL"
            '''
        }
    }
}