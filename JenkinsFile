pipeline {
    agent any

    environment {
        TELEGRAM_TOKEN = credentials('8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo')
        TELEGRAM_CHAT_ID = credentials('1653989745')
    }

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/Nuth68/laravel-test-jenkins.git'
            }
        }

        stage('Build Laravel') {
            steps {
                sh '''
                composer install
                php artisan key:generate
                npm install
                npm run build
                '''
            }
        }
    }

    post {
        success {
            script {
                sh """
                curl -s -X POST https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage \
                -d chat_id=${TELEGRAM_CHAT_ID} \
                -d text="✅ SUCCESS: ${JOB_NAME}"
                """
            }
        }

        failure {
            script {
                node {
                    sh """
                    curl -s -X POST https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage \
                    -d chat_id=${TELEGRAM_CHAT_ID} \
                    -d text="❌ FAILED: ${JOB_NAME}"
                    """
                }
            }
        }
    }
}