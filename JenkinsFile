pipeline {
    agent {label 'laravel'}
    stages {
        stage('Build Laravel') {
    steps {
        sh '''
            cp .env.example .env
            composer install
            php artisan key:generate
            npm install
            npm run build
        '''
    }
}
        
    }

    post {
        success {
            node('laravel'){
            sh """
            curl -s -X POST https://api.telegram.org/bot8725417417:AAEJYP7PnCqfKgMaAq7yNIZmTuRPCIbXkig/sendMessage \
                 -d chat_id=1653989745 \
                 -d text="✅ Build Success"
            """
            }
        }
        failure {
            node ('laravel') {
                sh '''
                curl -s -X POST https://api.telegram.org/bot8725417417:AAEJYP7PnCqfKgMaAq7yNIZmTuRPCIbXkig/sendMessage \
                -d chat_id=1653989745 \
                -d text="❌ Build Failed" 
                '''
            }
        }
    }
}