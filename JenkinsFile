pipeline {
    agent any

    environment {
        TELEGRAM_TOKEN = "8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo"
        TELEGRAM_CHAT_ID = "1653989745"

        TEXT_PRE_BUILD = "🚀 Jenkins building ${JOB_NAME}"
        TEXT_SUCCESS_BUILD = "✅ ${JOB_NAME} SUCCESS"
        TEXT_FAILURE_BUILD = "❌ ${JOB_NAME} FAILED"
        TEXT_ABORTED_BUILD = "⚠️ ${JOB_NAME} ABORTED"
    }

    stages {

        stage("Pre-Build") {
            steps {
                sh '''
                curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
                -d chat_id="$TELEGRAM_CHAT_ID" \
                -d text="$TEXT_PRE_BUILD"
                '''
            }
        }

        stage("Test") {
            steps {
                echo 'Testing...'
                // 🔥 force failure to test
                // sh 'exit 1'
            }
        }
    }

    post {

        success {
            sh '''
            curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
            -d chat_id="$TELEGRAM_CHAT_ID" \
            -d text="$TEXT_SUCCESS_BUILD"
            '''
        }

        failure {
            sh '''
            curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
            -d chat_id="$TELEGRAM_CHAT_ID" \
            -d text="$TEXT_FAILURE_BUILD"
            '''
        }

        aborted {
            sh '''
            curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_TOKEN/sendMessage" \
            -d chat_id="$TELEGRAM_CHAT_ID" \
            -d text="$TEXT_ABORTED_BUILD"
            '''
        }
    }
}