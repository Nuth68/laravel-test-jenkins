pipeline {
    agent any

    environment {
        // Set your Jenkins credentials for Telegram
        TELEGRAM_TOKEN = credentials('8623369528:AAFcJCLUJ0ZhYuNpZhEBJiItbGMpmgE_UKo')  // Replace with your Jenkins credential ID
        TELEGRAM_CHAT_ID = credentials('1653989745')    // Replace with your Jenkins credential ID
    }

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/Nuth68/laravel-test-jenkins.git'
            }
        }

        stage('Build Laravel') {
            steps {
                sh '''
                    composer install
                    php artisan key:generate
                    npm install
                    npm run build
                '''
            }
        }
    }

    post {
        success {
            echo "Build succeeded ✅"
        }
        failure {
            echo "Build failed ❌"
            script {
                // Send Telegram message on failure
                sh """
                curl -s -X POST https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage \
                -d chat_id=${TELEGRAM_CHAT_ID} \
                -d text="❌ Jenkins Build Failed! Job: ${JOB_NAME} #${BUILD_NUMBER} \nCheck console: ${BUILD_URL}"
                """
            }
        }
    }
}