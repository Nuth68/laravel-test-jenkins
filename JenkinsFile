pipeline {
    agent {label 'laravel'}
    stages {
        stage('Build') {
            steps {
                sh '''
                    composer install
                    php artisan key:generate
                    npm install
                    npm run build
                '''
            }
        }
        stage('Setup Environment') {
              steps {
                 sh '''
                    if [ ! -f .env ]; then
                      cp .env.example .env
                    fi
                     php artisan key:generate
                     '''
                 }
        }
        
    }

    post {
        success {
            node('laravel'){
            sh """
            curl -s -X POST https://api.telegram.org/bot8725417417:AAEJYP7PnCqfKgMaAq7yNIZmTuRPCIbXkig/sendMessage \
                 -d chat_id=1653989745 \
                 -d text="✅ Build Success"
            """
            }
        }
        failure {
            node ('laravel') {
                sh '''
                curl -s -X POST https://api.telegram.org/bot8725417417:AAEJYP7PnCqfKgMaAq7yNIZmTuRPCIbXkig/sendMessage \
                -d chat_id=1653989745 \
                -d text="❌ Build Failed" 
                '''
            }
        }
    }
}